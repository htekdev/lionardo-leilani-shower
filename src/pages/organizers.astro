---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import CelebrationDetails from '../components/CelebrationDetails.astro';
import MilestonesSection from '../components/MilestonesSection.astro';
import Registry from '../components/Registry.astro';
import Footer from '../components/Footer.astro';

const notes = [
  {
    icon: '📅',
    title: 'Date update underway',
    body: 'We already reached out to Paula to confirm the new shower date. Once she replies, this page will reflect the final celebration plans right away.',
  },
  {
    icon: '🤍',
    title: 'How to support the family',
    body: 'Prayers, encouragement, thoughtful gifts, and steady love all matter right now as the Rocha family continues this NICU season with Leilani and Leo.',
  },
  {
    icon: '✨',
    title: 'Why this page exists',
    body: 'This celebration page is here to keep loved ones connected to the story, the hope, and the joy waiting on the other side of the NICU journey.',
  },
];
---

<BaseLayout
  title="Celebration Details — Leilani & Leo's Baby Shower"
  description="Details and support information for Leilani and Leo's baby shower celebration."
>
  <Navbar />

  <main id="main-content" class="pt-20">
    <section class="py-16 px-4 bg-gradient-to-br from-accent-blue/10 to-accent-pink/10">
      <div class="max-w-4xl mx-auto text-center fade-in">
        <p class="uppercase tracking-[0.3em] text-xs font-semibold text-accent-pink mb-4">Celebration details</p>
        <h1 class="font-heading font-bold text-4xl sm:text-5xl gradient-text mb-4">
          Leilani & Leo's shower update
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed max-w-3xl mx-auto">
          This page is for family and friends who want the latest on the celebration, the twins' journey, and the sweetest ways to show love while everyone waits for homecoming day.
        </p>
      </div>
    </section>

    <section class="py-12 px-4 -mt-8">
      <div class="max-w-5xl mx-auto grid gap-4 md:grid-cols-3">
        {notes.map((note, index) => (
          <article class="bg-white rounded-3xl p-6 shadow-sm border border-border-default fade-in" style={`animation-delay: ${index * 0.1}s`}>
            <div class="text-3xl mb-3">{note.icon}</div>
            <h2 class="font-heading font-semibold text-2xl text-text-primary mb-2">{note.title}</h2>
            <p class="text-text-secondary leading-relaxed">{note.body}</p>
          </article>
        ))}
      </div>
    </section>

    <CelebrationDetails />
    <MilestonesSection />
    <Registry />
  </main>

  <Footer />
</BaseLayout>
