---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import CelebrationDetails from '../components/CelebrationDetails.astro';
import StorySection from '../components/StorySection.astro';
import MilestonesSection from '../components/MilestonesSection.astro';
import OutlookSection from '../components/OutlookSection.astro';
import Registry from '../components/Registry.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Leilani & Leo's Baby Shower"
  description="A heartfelt baby shower celebration page honoring Leilani and Leo, their NICU journey, and the Rocha family's love."
>
  <Navbar />
  <main id="main-content">
    <Hero />
    <CelebrationDetails />
    <StorySection />
    <MilestonesSection />
    <OutlookSection />
    <Registry />
  </main>
  <Footer />
</BaseLayout>
