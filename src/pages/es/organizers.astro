---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import CelebrationDetails from '../../components/CelebrationDetails.astro';
import MilestonesSection from '../../components/MilestonesSection.astro';
import Registry from '../../components/Registry.astro';
import Footer from '../../components/Footer.astro';

const notes = [
  {
    icon: '📅',
    title: 'Actualización de fecha en proceso',
    body: 'Ya le escribimos a Paula para confirmar la nueva fecha del shower. En cuanto responda, esta página reflejará los planes finales.',
  },
  {
    icon: '🤍',
    title: 'Cómo apoyar a la familia',
    body: 'Las oraciones, el ánimo, los regalos con intención y el cariño constante importan muchísimo mientras la familia Rocha sigue esta temporada en NICU con Leilani y Leo.',
  },
  {
    icon: '✨',
    title: 'Por qué existe esta página',
    body: 'Esta página de celebración ayuda a que familia y amigos sigan conectados con la historia, la esperanza y la alegría que espera al otro lado de la jornada en NICU.',
  },
];
---

<BaseLayout
  title="Detalles de la celebración — Baby Shower de Leilani y Leo"
  description="Detalles e información de apoyo para la celebración del baby shower de Leilani y Leo."
>
  <Navbar />

  <main id="main-content" class="pt-20">
    <section class="py-16 px-4 bg-gradient-to-br from-accent-blue/10 to-accent-pink/10">
      <div class="max-w-4xl mx-auto text-center fade-in">
        <p class="uppercase tracking-[0.3em] text-xs font-semibold text-accent-pink mb-4">Detalles de la celebración</p>
        <h1 class="font-heading font-bold text-4xl sm:text-5xl gradient-text mb-4">
          Actualización del shower de Leilani y Leo
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed max-w-3xl mx-auto">
          Esta página es para familia y amigos que quieren lo más reciente sobre la celebración, la jornada de los bebés y las maneras más lindas de demostrar amor mientras todos esperan el día de volver a casa.
        </p>
      </div>
    </section>

    <section class="py-12 px-4 -mt-8">
      <div class="max-w-5xl mx-auto grid gap-4 md:grid-cols-3">
        {notes.map((note, index) => (
          <article class="bg-white rounded-3xl p-6 shadow-sm border border-border-default fade-in" style={`animation-delay: ${index * 0.1}s`}>
            <div class="text-3xl mb-3">{note.icon}</div>
            <h2 class="font-heading font-semibold text-2xl text-text-primary mb-2">{note.title}</h2>
            <p class="text-text-secondary leading-relaxed">{note.body}</p>
          </article>
        ))}
      </div>
    </section>

    <CelebrationDetails />
    <MilestonesSection />
    <Registry />
  </main>

  <Footer />
</BaseLayout>
