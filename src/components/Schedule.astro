---
const schedule = [
  { time: '3:00 PM', title: 'Party Starts', desc: 'Welcome & Mingle', icon: '🎉' },
  { time: '4:30 PM', title: 'Games Begin', desc: 'Fun for everyone!', icon: '🎮' },
  { time: '5:00 PM', title: 'Food Served', desc: 'Fresh tacos by Jasmine!', icon: '🌮' },
  { time: '6:00 PM', title: 'Cake & Gifts', desc: 'Sweet celebration', icon: '🎂' },
  { time: '7:00 PM', title: 'Goodbye', desc: 'Cleanup & farewells', icon: '👋' },
];
---

<section class="py-20 px-4 bg-bg-surface" id="schedule">
  <div class="max-w-4xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-in">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl gradient-text mb-4">
        Party Schedule
      </h2>
      <p class="text-text-secondary">Here's what to expect throughout the day!</p>
    </div>
    
    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical Line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent-blue via-accent-pink to-accent-blue transform md:-translate-x-1/2"></div>
      
      <!-- Timeline Items -->
      {schedule.map((item, index) => (
        <div class={`relative flex items-center mb-12 fade-in ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
          <!-- Timeline Dot -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-gradient-to-r from-accent-blue to-accent-pink transform -translate-x-1/2 z-10 ring-4 ring-bg-surface"></div>
          
          <!-- Content Card -->
          <div class={`ml-12 md:ml-0 md:w-5/12 ${index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
            <div class="glass rounded-2xl p-6 hover:shadow-lg transition-shadow">
              <div class={`flex items-center gap-3 mb-2 ${index % 2 === 0 ? 'md:justify-end' : ''}`}>
                <span class="text-2xl">{item.icon}</span>
                <span class="text-sm font-bold text-text-primary bg-white px-3 py-1 rounded-full shadow-sm border border-accent-pink/30">
                  {item.time}
                </span>
              </div>
              <h3 class="font-heading font-semibold text-xl text-text-primary mb-1">{item.title}</h3>
              <p class="text-text-secondary">{item.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
