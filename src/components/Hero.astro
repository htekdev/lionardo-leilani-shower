---
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden" id="hero">
  <!-- Soft cream/beige base background -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#F5EDE8] via-[#FDF8F3] to-[#FEFCFB]"></div>
  
  <!-- Balloon decorations - matching invite style -->
  <!-- Top left balloon cluster -->
  <div class="absolute top-8 left-8 w-24 h-32 bg-gradient-to-b from-[#A7D3E8] to-[#8BC4DC] rounded-full opacity-80 blur-[2px]"></div>
  <div class="absolute top-16 left-28 w-20 h-28 bg-gradient-to-b from-[#F5D5D5] to-[#E8B4B4] rounded-full opacity-80 blur-[2px]"></div>
  <div class="absolute top-4 left-44 w-18 h-24 bg-gradient-to-b from-[#D4C4B0] to-[#C4B49A] rounded-full opacity-70 blur-[2px]"></div>
  <div class="absolute top-24 left-12 w-16 h-22 bg-gradient-to-b from-[#F5D5D5] to-[#E8B4B4] rounded-full opacity-60 blur-[2px]"></div>
  <div class="absolute top-10 left-56 w-14 h-20 bg-gradient-to-b from-[#A7D3E8] to-[#8BC4DC] rounded-full opacity-60 blur-[2px]"></div>
  
  <!-- Top right balloon cluster -->
  <div class="absolute top-8 right-8 w-24 h-32 bg-gradient-to-b from-[#F5D5D5] to-[#E8B4B4] rounded-full opacity-80 blur-[2px]"></div>
  <div class="absolute top-16 right-28 w-20 h-28 bg-gradient-to-b from-[#A7D3E8] to-[#8BC4DC] rounded-full opacity-80 blur-[2px]"></div>
  <div class="absolute top-4 right-44 w-18 h-24 bg-gradient-to-b from-[#D4C4B0] to-[#C4B49A] rounded-full opacity-70 blur-[2px]"></div>
  <div class="absolute top-24 right-12 w-16 h-22 bg-gradient-to-b from-[#A7D3E8] to-[#8BC4DC] rounded-full opacity-60 blur-[2px]"></div>
  <div class="absolute top-10 right-56 w-14 h-20 bg-gradient-to-b from-[#F5D5D5] to-[#E8B4B4] rounded-full opacity-60 blur-[2px]"></div>
  
  <!-- Small stars/sparkles scattered -->
  <div class="absolute top-1/4 left-1/4 text-[#A7D3E8] text-xl opacity-60">✦</div>
  <div class="absolute top-1/3 right-1/3 text-[#F5D5D5] text-lg opacity-50">✦</div>
  <div class="absolute bottom-1/3 left-1/5 text-[#EC4899] text-sm opacity-40">★</div>
  <div class="absolute bottom-1/4 right-1/4 text-[#0EA5E9] text-base opacity-50">✦</div>
  
  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Small hearts decoration -->
    <div class="flex justify-center gap-4 mb-6">
      <span class="text-accent-blue text-2xl">💙</span>
      <span class="text-accent-pink text-2xl">💗</span>
    </div>
    
    <!-- Main Title -->
    <h1 class="font-heading font-bold text-5xl sm:text-6xl md:text-7xl mb-4 fade-in">
      <span class="gradient-text">Leonardo</span>
      <span class="text-text-secondary mx-2">&</span>
      <span class="gradient-text">Leilani</span>
    </h1>
    
    <!-- Subtitle -->
    <p class="text-xl sm:text-2xl text-text-secondary mb-8 font-heading fade-in" style="animation-delay: 0.2s">
      A Baby Shower for <span class="text-accent-pink font-semibold">Paula</span>
    </p>
    
    <!-- Date & Location -->
    <div class="space-y-2 fade-in" style="animation-delay: 0.4s">
      <p class="text-lg sm:text-xl text-text-primary font-medium">
        📅 March 7th, 2026 • 3:00 PM
      </p>
      <p class="text-text-muted">
        📍 Viki's House
      </p>
    </div>
  </div>
  
  <!-- Scroll indicator - positioned relative to section -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }
  
  .animate-pulse {
    animation: pulse 4s ease-in-out infinite;
  }
  
  .delay-1000 {
    animation-delay: 1s;
  }
</style>
