---
// Hero with AI-generated watercolor background matching invite
const basePath = import.meta.env.BASE_URL;
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden" id="hero">
  <!-- Warm cream background base -->
  <div class="absolute inset-0 bg-[#FAF6F1]"></div>
  
  <!-- Mobile: Portrait background image -->
  <div 
    class="absolute inset-0 bg-cover bg-center bg-no-repeat md:hidden"
    style={`background-image: url('${basePath}/hero-bg-mobile.png');`}
  ></div>
  
  <!-- Desktop: Landscape background image -->
  <div 
    class="absolute inset-0 bg-cover bg-center bg-no-repeat hidden md:block"
    style={`background-image: url('${basePath}/hero-bg.png');`}
  ></div>
  
  <!-- Soft overlay to ensure text readability -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#FAF6F1]/30 via-transparent to-[#FAF6F1]/40"></div>
  
  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Small hearts decoration -->
    <div class="flex justify-center gap-4 mb-6">
      <span class="text-2xl">💙</span>
      <span class="text-2xl">💗</span>
    </div>
    
    <!-- Main Title with gradient -->
    <h1 class="font-heading font-bold text-5xl sm:text-6xl md:text-7xl mb-4 fade-in">
      <span class="gradient-text">Leonardo</span>
      <span class="text-text-secondary mx-2">&</span>
      <span class="gradient-text">Leilani</span>
    </h1>
    
    <!-- Subtitle -->
    <p class="text-xl sm:text-2xl text-text-secondary mb-8 font-heading fade-in" style="animation-delay: 0.2s">
      A Baby Shower for <span class="text-accent-pink font-semibold">Paula</span>
    </p>
    
    <!-- Date & Location Card -->
    <div class="inline-block bg-white/80 backdrop-blur-sm rounded-2xl px-8 py-4 shadow-lg fade-in" style="animation-delay: 0.4s">
      <p class="text-lg sm:text-xl text-text-primary font-medium">
        📅 March 7th, 2026 • 3:00 PM
      </p>
      <p class="text-text-muted mt-1">
        📍 Viki's House
      </p>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
