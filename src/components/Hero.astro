---
import { getLangFromUrl } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = (key: keyof typeof ui['en']) => ui[lang][key] || ui['en'][key];

const basePath = import.meta.env.BASE_URL;
const babyNames = lang === 'es' ? 'Leilani y Leo' : 'Leilani & Leo';
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden" id="hero">
  <div class="absolute inset-0 bg-[#FAF6F1]"></div>

  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat md:hidden"
    style={`background-image: url('${basePath}/hero-bg-mobile.png');`}
  ></div>

  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat hidden md:block"
    style={`background-image: url('${basePath}/hero-bg.png');`}
  ></div>

  <div class="absolute inset-0 bg-gradient-to-b from-[#FAF6F1]/25 via-[#FAF6F1]/45 to-[#FAF6F1]/80"></div>

  <div class="relative z-10 text-center px-4 max-w-5xl mx-auto pt-16">
    <div class="flex justify-center gap-4 mb-6 fade-in">
      <span class="text-2xl">💙</span>
      <span class="text-2xl">💗</span>
      <span class="text-2xl">✨</span>
    </div>

    <p class="uppercase tracking-[0.35em] text-xs sm:text-sm text-text-secondary font-semibold mb-4 fade-in">
      {t('hero.subtitle')}
    </p>

    <h1 class="font-heading font-bold text-5xl sm:text-6xl md:text-7xl mb-4 fade-in" style="animation-delay: 0.1s">
      <span class="gradient-text">{babyNames}</span>
    </h1>

    <p class="text-xl sm:text-2xl text-text-secondary mb-6 font-heading fade-in" style="animation-delay: 0.2s">
      {t('hero.tagline')}
    </p>

    <p class="max-w-3xl mx-auto text-base sm:text-lg text-text-secondary leading-relaxed mb-8 fade-in" style="animation-delay: 0.3s">
      {t('hero.message')}
    </p>

    <div class="inline-flex flex-col gap-3 bg-white/85 backdrop-blur-sm rounded-[2rem] px-8 py-5 shadow-lg border border-border-default fade-in" style="animation-delay: 0.4s">
      <p class="text-lg sm:text-xl text-text-primary font-medium">
        📅 {t('hero.date')}
      </p>
      <p class="text-text-muted">
        📍 {t('hero.location')}
      </p>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
