---
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden" id="hero">
  <!-- Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent-blue/20 via-bg-cream to-accent-pink/20"></div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-20 left-10 w-16 h-16 bg-accent-blue/30 rounded-full blur-xl animate-pulse"></div>
  <div class="absolute bottom-32 right-16 w-24 h-24 bg-accent-pink/30 rounded-full blur-xl animate-pulse delay-1000"></div>
  <div class="absolute top-1/3 right-1/4 w-8 h-8 bg-accent-pink/40 rounded-full blur-lg"></div>
  <div class="absolute bottom-1/4 left-1/3 w-12 h-12 bg-accent-blue/40 rounded-full blur-lg"></div>
  
  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Small hearts decoration -->
    <div class="flex justify-center gap-4 mb-6">
      <span class="text-accent-blue text-2xl">💙</span>
      <span class="text-accent-pink text-2xl">💗</span>
    </div>
    
    <!-- Main Title -->
    <h1 class="font-heading font-bold text-5xl sm:text-6xl md:text-7xl mb-4 fade-in">
      <span class="gradient-text">Lionardo</span>
      <span class="text-text-secondary mx-2">&</span>
      <span class="gradient-text">Leilani</span>
    </h1>
    
    <!-- Subtitle -->
    <p class="text-xl sm:text-2xl text-text-secondary mb-8 font-heading fade-in" style="animation-delay: 0.2s">
      A Baby Shower for <span class="text-accent-pink font-semibold">Paula</span>
    </p>
    
    <!-- Date & Location -->
    <div class="space-y-2 fade-in" style="animation-delay: 0.4s">
      <p class="text-lg sm:text-xl text-text-primary font-medium">
        📅 March 7th, 2026 • 3:00 PM
      </p>
      <p class="text-text-muted">
        📍 Viki's House
      </p>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }
  
  .animate-pulse {
    animation: pulse 4s ease-in-out infinite;
  }
  
  .delay-1000 {
    animation-delay: 1s;
  }
</style>
