---
---

<section class="py-20 px-4 bg-bg-surface" id="food">
  <div class="max-w-4xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12 fade-in">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl gradient-text mb-4">
        Food & Drinks
      </h2>
      <p class="text-text-secondary">Delicious eats coming your way!</p>
    </div>
    
    <!-- Featured: Jasmine's Tacos -->
    <div class="glass rounded-3xl p-8 mb-8 text-center fade-in">
      <div class="text-6xl mb-4">🌮</div>
      <h3 class="font-heading font-bold text-2xl sm:text-3xl text-text-primary mb-2">
        Fresh Tacos by Jasmine
      </h3>
      <p class="text-accent-pink font-medium text-lg mb-4">
        "The Taco Lady" 👩‍🍳
      </p>
      <p class="text-text-secondary max-w-md mx-auto">
        Get ready for amazing homemade tacos cooked fresh on-site! 
        Jasmine is known for her incredible flavors that everyone loves.
      </p>
      <div class="mt-4 text-sm text-text-muted">
        🕐 Serving starts at 5:00 PM
      </div>
    </div>
    
    <!-- Other Food Items -->
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Drinks -->
      <div class="glass rounded-2xl p-6 text-center fade-in">
        <div class="text-4xl mb-3">🥤</div>
        <h4 class="font-heading font-semibold text-lg text-text-primary mb-2">Drinks</h4>
        <p class="text-text-secondary text-sm">
          Sodas and refreshments provided by family
        </p>
      </div>
      
      <!-- Cake -->
      <div class="glass rounded-2xl p-6 text-center fade-in">
        <div class="text-4xl mb-3">🎂</div>
        <h4 class="font-heading font-semibold text-lg text-text-primary mb-2">Cake</h4>
        <p class="text-text-secondary text-sm">
          Special celebration cake from HEB
        </p>
      </div>
    </div>
  </div>
</section>
