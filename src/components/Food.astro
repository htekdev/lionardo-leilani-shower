---
import { getLangFromUrl } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = (key: keyof typeof ui['en']) => ui[lang][key] || ui['en'][key];
---

<section class="py-20 px-4 bg-bg-surface" id="food">
  <div class="max-w-4xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12 fade-in">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl gradient-text mb-4">
        {t('food.title')}
      </h2>
      <p class="text-text-secondary">{t('food.subtitle')}</p>
    </div>
    
    <!-- Featured: Jasmine's Tacos -->
    <div class="glass rounded-3xl p-8 mb-8 text-center fade-in">
      <div class="text-6xl mb-4">🌮</div>
      <h3 class="font-heading font-bold text-2xl sm:text-3xl text-text-primary mb-2">
        {t('food.tacos')}
      </h3>
      <p class="text-accent-pink font-medium text-lg mb-4">
        {t('food.tacoLady')}
      </p>
      <p class="text-text-secondary max-w-md mx-auto">
        {t('food.tacosDesc')}
      </p>
      <div class="mt-4 text-sm text-text-muted">
        {t('food.servingTime')}
      </div>
    </div>
    
    <!-- Other Food Items -->
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Drinks -->
      <div class="glass rounded-2xl p-6 text-center fade-in">
        <div class="text-4xl mb-3">🥤</div>
        <h4 class="font-heading font-semibold text-lg text-text-primary mb-2">{t('food.drinks')}</h4>
        <p class="text-text-secondary text-sm">
          {t('food.drinksDesc')}
        </p>
      </div>
      
      <!-- Cake -->
      <div class="glass rounded-2xl p-6 text-center fade-in">
        <div class="text-4xl mb-3">🎂</div>
        <h4 class="font-heading font-semibold text-lg text-text-primary mb-2">{t('food.cake')}</h4>
        <p class="text-text-secondary text-sm">
          {t('food.cakeDesc')}
        </p>
      </div>
    </div>
  </div>
</section>
