---
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = (key: keyof typeof ui['en']) => ui[lang][key] || ui['en'][key];
---

<footer class="py-12 px-4 bg-bg-overlay border-t border-border-default">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Hearts decoration -->
    <div class="flex justify-center gap-2 mb-4">
      <span class="text-accent-blue">💙</span>
      <span class="text-accent-pink">💗</span>
    </div>
    
    <!-- Message -->
    <p class="font-heading text-lg text-text-primary mb-2">
      {t('footer.welcome').split('Leonardo & Leilani')[0]}
      <span class="gradient-text font-semibold">Leonardo & Leilani</span>
      {t('footer.welcome').split('Leonardo & Leilani')[1]}
    </p>
    <p class="text-text-secondary text-sm mb-6">
      {t('footer.cantWait')}
    </p>
    
    <!-- Links -->
    <div class="flex justify-center gap-6 mb-6">
      <a href={getLocalizedPath('/', lang)} class="text-text-muted hover:text-accent-pink transition-colors text-sm">
        {t('nav.home')}
      </a>
      <span class="text-border-default">|</span>
      <a href={getLocalizedPath('/organizers', lang)} class="text-text-muted hover:text-accent-pink transition-colors text-sm">
        {t('nav.organizers')}
      </a>
    </div>
    
    <!-- Made with love -->
    <p class="text-text-muted text-xs">
      {t('footer.madeWith')}
    </p>
  </div>
</footer>
