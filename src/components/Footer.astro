---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<footer class="py-12 px-4 bg-bg-overlay border-t border-border-default">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Hearts decoration -->
    <div class="flex justify-center gap-2 mb-4">
      <span class="text-accent-blue">💙</span>
      <span class="text-accent-pink">💗</span>
    </div>
    
    <!-- Message -->
    <p class="font-heading text-lg text-text-primary mb-2">
      Welcome to the world, <span class="gradient-text font-semibold">Leonardo & Leilani</span>!
    </p>
    <p class="text-text-secondary text-sm mb-6">
      We can't wait to meet you both. 🥰
    </p>
    
    <!-- Links -->
    <div class="flex justify-center gap-6 mb-6">
      <a href={base} class="text-text-muted hover:text-accent-pink transition-colors text-sm">
        Home
      </a>
      <span class="text-border-default">|</span>
      <a href={`${base}organizers`} class="text-text-muted hover:text-accent-pink transition-colors text-sm">
        Organizers
      </a>
    </div>
    
    <!-- Made with love -->
    <p class="text-text-muted text-xs">
      Made with 💕 for Paula's baby shower
    </p>
  </div>
</footer>
