---
import { getLangFromUrl } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = (key: keyof typeof ui['en']) => ui[lang][key] || ui['en'][key];

const games = [
  {
    icon: '🍼',
    title: t('games.babyFood'),
    desc: t('games.babyFoodDesc'),
    forGuys: false,
  },
  {
    icon: '🏃',
    title: t('games.diaperRelay'),
    desc: t('games.diaperRelayDesc'),
    forGuys: true,
    tag: t('games.diaperRelayTag'),
  },
  {
    icon: '📏',
    title: t('games.bellyMeasure'),
    desc: t('games.bellyMeasureDesc'),
    forGuys: false,
  },
  {
    icon: '💩',
    title: t('games.dirtyDiaper'),
    desc: t('games.dirtyDiaperDesc'),
    forGuys: false,
  },
  {
    icon: '📎',
    title: t('games.clothespin'),
    desc: t('games.clothespinDesc'),
    forGuys: false,
  },
];
---

<section class="py-20 px-4" id="games">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12 fade-in">
      <h2 class="font-heading font-bold text-3xl sm:text-4xl gradient-text mb-4">
        {t('games.title')}
      </h2>
      <p class="text-text-secondary mb-2">{t('games.subtitle')}</p>
      <p class="text-sm text-accent-pink font-medium">{t('games.prizes')}</p>
    </div>
    
    <!-- Games Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {games.map((game, index) => (
        <div class="glass rounded-2xl p-6 hover:scale-105 transition-transform fade-in" style={`animation-delay: ${index * 0.1}s`}>
          <div class="text-4xl mb-4">{game.icon}</div>
          <h3 class="font-heading font-semibold text-xl text-text-primary mb-2">
            {game.title}
            {game.forGuys && (
              <span class="ml-2 text-xs bg-accent-blue/20 text-accent-blue-dark px-2 py-1 rounded-full">
                {game.tag}
              </span>
            )}
          </h3>
          <p class="text-text-secondary text-sm">{game.desc}</p>
        </div>
      ))}
    </div>
    
    <!-- Fun note -->
    <p class="text-center text-text-muted mt-8 fade-in">
      {t('games.warning')}
    </p>
  </div>
</section>
