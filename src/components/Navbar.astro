---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/organizers', label: 'Organizers' },
];
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo/Title -->
      <a href={base} class="font-heading font-bold text-xl gradient-text">
        L & L
      </a>
      
      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a 
            href={link.href === '/' ? base : `${base}${link.href.slice(1)}`}
            class="text-text-secondary hover:text-accent-pink transition-colors font-medium"
          >
            {link.label}
          </a>
        ))}
      </div>
      
      <!-- Mobile Menu Button -->
      <button 
        class="md:hidden p-2 text-text-secondary hover:text-accent-pink"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div class="md:hidden hidden bg-bg-surface/95 backdrop-blur-lg border-t border-border-default" id="mobile-menu">
    <div class="px-4 py-4 space-y-2">
      {navLinks.map(link => (
        <a 
          href={link.href === '/' ? base : `${base}${link.href.slice(1)}`}
          class="block py-2 text-text-secondary hover:text-accent-pink transition-colors font-medium"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-bg-cream/90', 'backdrop-blur-lg', 'shadow-sm');
    } else {
      navbar?.classList.remove('bg-bg-cream/90', 'backdrop-blur-lg', 'shadow-sm');
    }
  });
  
  // Mobile menu toggle
  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
